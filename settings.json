{
    "C_Cpp.autocompleteAddParentheses": true,
    "C_Cpp.copilotHover": "disabled",
    "C_Cpp.default.cppStandard": "c++20",
    "C_Cpp.inlayHints.parameterNames.hideLeadingUnderscores": false,
    "C_Cpp.vcFormat.indent.accessSpecifiers": true,
    "C_Cpp.vcFormat.indent.braces": true,
    "[cpp]": {
        "editor.semanticHighlighting.enabled": true,
        "editor.suggest.insertMode": "replace",
        "editor.wordBasedSuggestions": "off"
    },
    "[java]": {
        "editor.suggest.snippetsPreventQuickSuggestions": false
    },
    "[latex]": {
        "editor.fontFamily": "Cartograph CF",
        "editor.fontWeight": "300"
    },
    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "[ruby]": {
        "editor.formatOnType": true, // Enable formatting while typing,
        "editor.insertSpaces": true, // Use spaces and not tabs for indentation
        "editor.semanticHighlighting.enabled": true, // Enable semantic highlighting
        "editor.tabSize": 2 // Use 2 spaces for indentation
    },
    "breadcrumbs.enabled": false,
    "cSpell.enabled": false,
    "chat.agent.enabled": false,
    "chat.agent.maxRequests": 0,
    "chat.commandCenter.enabled": false,
    "chat.disableAIFeatures": true,
    "chat.notifyWindowOnConfirmation": false,
    "cucumberautocomplete.formatConfOverride": {
        "Característica": 0,
        "Cuando": "relativeUp",
        "Dada": 2,
        "Dado": 2,
        "Ejemplos": 2,
        "Entonces": "relativeUp",
        "Escenario": 1,
        "Esquema del escenario": 1,
        "Y": "relativeUp"
    },
    "docker.lsp.telemetry": "off",
    "editor.cursorBlinking": "solid",
    // "editor.fontFamily": "CozetteVector",
    "editor.fontFamily": "Departure Mono",
    "editor.fontLigatures": true,
    "editor.fontSize": 18,
    "editor.fontVariations": false,
    // Espacio del gutter, gutter icons
    "editor.glyphMargin": false,
    "editor.guides.bracketPairs": true,
    "editor.guides.bracketPairsHorizontal": "active",
    "editor.guides.highlightActiveIndentation": true,
    "editor.inlineSuggest.enabled": true,
    "editor.letterSpacing": -1,
    "editor.lineHeight": 0.95,
    "editor.lineNumbers": "off",
    "editor.minimap.enabled": false,
    "editor.mouseWheelZoom": true,
    "editor.parameterHints.enabled": true,
    // Flechas para colapsar el código
    "editor.showFoldingControls": "never",
    "editor.stickyScroll.enabled": false,
    "editor.suggestSelection": "first",
    "editor.tabCompletion": "on",
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            // Ruby
            {
                "scope": [
                    "comment.line.keyword.yard.ruby",
                    "comment.line.number-sign.ruby",
                    "comment.line.keyword.punctuation.yard.ruby",
                    "comment.line.punctuation.yard.ruby",
                    "comment.line.type.yard.ruby",
                    "punctuation.definition.comment.ruby"
                ],
                "settings": {
                    "foreground": "#ffffff41"
                }
            },
            {
                "scope": [
                    "meta.embedded.line.ruby"
                ],
                "settings": {
                    "fontStyle": "italic",
                    "foreground": "#f700ff"
                }
            },
            {
                "scope": [
                    "variable.other.constant.ruby"
                ],
                "settings": {
                    "fontStyle": "italic bold",
                    "foreground": "#ff00c8"
                }
            },
            {
                "scope": [
                    "support.class.ruby"
                ],
                "settings": {
                    "fontStyle": "italic bold",
                    "foreground": "#A95EFF"
                }
            }
            // Python
            ,
            {
                "scope": [
                    "source.python comment",
                    "source.python punctuation.definition.comment",
                    "source.python string.quoted.docstring.multi"
                ],
                "settings": {
                    "foreground": "#4faf37"
                }
            },
            {
                "scope": [
                    "keyword.language.gherkin.feature"
                ],
                "settings": {
                    "foreground": "#fbff00"
                }
            },
            {
                "scope": [
                    "keyword.language.gherkin.feature.step"
                ],
                "settings": {
                    "foreground": "#1eff00"
                }
            },
            {
                "scope": [
                    "string.language.gherkin.feature.title",
                    "string.language.gherkin.scenario.title.title"
                ],
                "settings": {
                    "foreground": "#ff9215"
                }
            },
            {
                "scope": [
                    "entity.name.function.java"
                ],
                "settings": {
                    "foreground": "#ff0000"
                }
            },
            {
                "scope": [
                    "keyword.other.import.java",
                    "keyword.other.package.java"
                ],
                "settings": {
                    "fontStyle": "bold",
                    "foreground": "#ff00dd"
                }
            },
            {
                "scope": [
                    "entity.name.type.class.java"
                ],
                "settings": {
                    "fontStyle": "bold",
                    "foreground": "#cc00ff"
                }
            },
            {
                "scope": [
                    "meta.class.body.java"
                ],
                "settings": {
                    "foreground": "#28A9FF"
                }
            },
            {
                "scope": [
                    "comment",
                    "punctuation.definition.comment"
                ],
                "settings": {
                    "foreground": "#AAAAAA"
                }
            },
            {
                "scope": [
                    "keyword.other.special-method.dockerfile"
                ],
                "settings": {
                    "foreground": "#a200ff"
                }
            },
            {
                "scope": [
                    "source.dockerfile"
                ],
                "settings": {
                    "foreground": "#8883ca"
                }
            },
            {
                "scope": [
                    "comment.line.number-sign.dockerfile"
                ],
                "settings": {
                    "foreground": "#00ff88"
                }
            },
            // Html (dentro de Markdown)
            {
                "scope": [
                    "meta.attribute.src.html"
                ],
                "settings": {
                    "fontStyle": "italic underline"
                }
            },
            {
                "scope": [
                    "string.quoted.double.html"
                ],
                "settings": {
                    "foreground": "#fd1eebfd"
                }
            },
            // Latex (.tex file)
            {
                "scope": [
                    "meta.function",
                    "text.tex.latex"
                ],
                "settings": {
                    "foreground": "#ffffff"
                }
            },
            {
                "scope": [
                    "support.class.math.block.environment.latex"
                ],
                "settings": {
                    "foreground": "#1ca149"
                }
            }
        ]
    },
    "editor.wordWrap": "on",
    "explorer.compactFolders": false,
    "files.associations": {
        "*.rb": "ruby"
    },
    "files.exclude": {
        "**/.DS_Store": true,
        "**/.git": false,
        "**/.hg": true,
        "**/.ruby-lsp": false,
        "**/.svn": true,
        "**/CVS": true,
        "**/Thumbs.db": true
    },
